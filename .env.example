# Application
NODE_ENV=development
PORT=3001
# フロントエンドのオリジン（CORS設定に使用）
FRONTEND_URL=http://localhost:3000
# アプリケーションURL（パスワードリセットリンク生成に使用）
APP_URL=http://localhost:3000

# Database (SQLite for development)
DB_PATH=./data/pla-ledger.sqlite

# Database (PostgreSQL for production - set DATABASE_URL instead of DB_PATH)
# DATABASE_URL=postgres://plaledger:your_password_here@localhost:5432/plaledger
DB_PASSWORD=your_secure_password_here

# Authentication
JWT_SECRET=pla-ledger-dev-secret-change-in-production

# CORS (production)
# CORS_ORIGIN=https://yourdomain.com

# Logging
LOG_LEVEL=info
LOG_DIR=backend/logs

# ========== メール送信設定 ==========

# メール送信元
EMAIL_FROM=noreply@plaledger.com
EMAIL_FROM_NAME=PlaLedger

# SMTP設定（開発環境：Mailhog）
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# SMTP設定例（Gmail）
# GmailでSMTPを使用する場合は「アプリパスワード」を生成してください
# 参考：https://support.google.com/accounts/answer/185833
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# SMTP設定例（Gmail SSL接続）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# SMTP設定例（SendGrid）
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key

# SMTP設定例（AWS SES）
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-aws-smtp-username
# SMTP_PASS=your-aws-smtp-password
